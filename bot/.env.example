# ── Telegram ──────────────────────────────────────────────────────────────────
# Get this from @BotFather after creating the bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated chat IDs or @usernames the bot is allowed to respond to.
# Get the numeric ID by forwarding a channel message to @userinfobot.
# Leave empty to respond to ALL chats (not recommended in production).
ALLOWED_CHATS=@mpc_deadlines,-1001234567890

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── GitHub ────────────────────────────────────────────────────────────────────
# Fine-grained PAT with:
#   - Contents: Read & Write  (to commit conferences.yml)
#   - Pull requests: Read & Write  (to open PRs)
GITHUB_TOKEN=your_github_pat_here

# Target repo and branch
GITHUB_REPO=mpc-deadlines/mpc-deadlines.github.io
GITHUB_BASE_BRANCH=main
CONFERENCES_FILE=_data/conferences.yml
